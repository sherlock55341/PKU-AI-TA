# LLM — OpenRouter (https://openrouter.ai)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-...
TA_MODEL=qwen/qwen3.5-397b-a17b

# PKU IAAA credentials (your PKU student/staff ID and password)
PKU_USERNAME=2300012345
PKU_PASSWORD=your_password

# Blackboard course ID — found in the URL of any course page, e.g. _98024_1
COURSE_ID=_98024_1

# Optional: pre-set a student whitelist (comma-separated IDs); empty = all students
# STUDENT_WHITELIST=2100012345,2100012346

# Optional: confidence threshold below which a score is flagged for human review (default 0.75)
# REVIEW_THRESHOLD=0.75

# Optional: disable chain-of-thought thinking tokens for Qwen3 models (faster + cheaper)
# ENABLE_THINKING=false

# Optional: number of parallel scoring threads (default 4)
# TA_THREADS=4
